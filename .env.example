# Anthropic API Key (required for Claude analysis)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# FRED API Key (required for macroeconomic data)
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# SMTP Email Configuration (required for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
NOTIFY_EMAIL_1=recipient1@example.com
NOTIFY_EMAIL_2=recipient2@example.com
